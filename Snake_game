<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>لعبة الثعبان</title>
<style>
  body { font-family: Arial; text-align: center; background: #111; color: #fff; }
  #gameCanvas { background: #222; display: block; margin: 20px auto; }
  .btn { font-size: 30px; margin: 5px; padding: 10px 15px; cursor: pointer; }
  #scoreboard { margin-top: 10px; }
</style>
</head>
<body>
<h1>مرحبا بلعبة الثعبان</h1>
<div id="nameDiv">
  <input type="text" id="playerName" placeholder="اكتب اسمك هنا">
  <button onclick="startGame()">ابدأ اللعبة</button>
</div>
<div id="welcomeDiv" style="display:none;">
  <h2 id="welcomeMsg"></h2>
</div>

<canvas id="gameCanvas" width="300" height="300"></canvas>
<div id="scoreboard">
  <h3>High Score: <span id="highScore">0</span></h3>
</div>

<div id="controls">
  <button class="btn" onclick="changeDirection('Up')">⬆️</button><br>
  <button class="btn" onclick="changeDirection('Left')">⬅️</button>
  <button class="btn" onclick="changeDirection('Down')">⬇️</button>
  <button class="btn" onclick="changeDirection('Right')">➡️</button>
</div>

<p>Endo المؤسس</p>

<script>
let canvas = document.getElementById("gameCanvas");
let ctx = canvas.getContext("2d");
let blockSize = 15;
let snake = [{x:150, y:150}];
let direction = 'Right';
let food = {x: Math.floor(Math.random()*20)*blockSize, y: Math.floor(Math.random()*20)*blockSize};
let score = 0;
let highScore = localStorage.getItem("highScore") || 0;
document.getElementById("highScore").innerText = highScore;

function startGame() {
  let name = document.getElementById("playerName").value.trim();
  if(!name) { alert("اكتب اسمك"); return; }
  document.getElementById("nameDiv").style.display="none";
  document.getElementById("welcomeDiv").style.display="block";
  document.getElementById("welcomeMsg").innerText = "مرحبا بعودتك " + name;
  snake = [{x:150, y:150}]; direction='Right'; score=0;
  clearInterval(window.snakeInterval);
  window.snakeInterval = setInterval(gameLoop, 150);
}

function changeDirection(dir){ direction = dir; }

function gameLoop(){
  ctx.fillStyle="#222"; ctx.fillRect(0,0,canvas.width,canvas.height);

  // حركة الثعبان
  let head = {x: snake[0].x, y: snake[0].y};
  if(direction=='Right') head.x += blockSize;
  if(direction=='Left') head.x -= blockSize;
  if(direction=='Up') head.y -= blockSize;
  if(direction=='Down') head.y += blockSize;
  
  // تحقق من الاصطدام بالحائط أو بنفسه
  if(head.x<0 || head.x>=canvas.width || head.y<0 || head.y>=canvas.height || snake.some(s=>s.x===head.x && s.y===head.y)){
    clearInterval(window.snakeInterval);
    if(score > highScore){ highScore = score; localStorage.setItem("highScore", highScore); }
    alert("انتهت اللعبة! هاي سكور: " + highScore);
    return;
  }
  
  snake.unshift(head);

  // أكل الطعام
  if(head.x===food.x && head.y===food.y){
    score++; 
    food={x: Math.floor(Math.random()*20)*blockSize, y: Math.floor(Math.random()*20)*blockSize};
  }else{
    snake.pop();
  }

  // رسم الطعام
  ctx.fillStyle="red"; ctx.fillRect(food.x, food.y, blockSize, blockSize);

  // رسم الثعبان
  ctx.fillStyle="lime";
  snake.forEach(s => ctx.fillRect(s.x, s.y, blockSize, blockSize));

  document.getElementById("highScore").innerText = Math.max(score, highScore);
}
</script>
</body>
</html>
